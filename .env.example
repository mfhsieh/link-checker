# SMTP Console 模式（true=只輸出到 console，false=實際發信）
SMTP_CONSOLE_MODE=false

# Gmail SMTP 設定
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USE_TLS=true

# 安全警告：請勿將真實帳密提交至版本控制系統
# 請在此填入您的 Gmail 帳號與 App Password（Google 帳戶 → 安全性 → 應用程式密碼）
SMTP_USERNAME=xxx@gmail.com
SMTP_PASSWORD=wwwwxxxxyyyyzzzz

# 寄件人顯示資訊
SMTP_FROM_NAME=外部連結檢查系統
SMTP_FROM_EMAIL=xxx@gmail.com

# 安全警告：生產環境請設為 false 或移除此行以防範 SSRF 攻擊
# 允許爬蟲存取本地端與私有 IP (僅供本地開發與測試時使用)
CRAWLER_ALLOW_LOCAL_IPS=false
