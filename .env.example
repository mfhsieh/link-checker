# ── 應用程式基本設定 ────────────────────────────────────────────────────────
# 系統顯示名稱
APP_NAME=外部連結檢查系統
# ⚠️ 安全警告：除錯模式開關（生產環境應設為 false）
DEBUG=false
# 系統對外網址（發送邀請信件時將以此作為基底，如 https://example.com）
BASE_URL=http://localhost:8000
# 任務詳情畫面的自動更新輪詢間隔（毫秒）
UI_POLL_INTERVAL=10000

# ── 資料庫設定 ─────────────────────────────────────────────────────────────
# ⚠️ 安全警告：帳號資料庫（Auth DB）的 SQLAlchemy 連線 DSN
AUTH_DB_URL=sqlite:///path/to/your/Auth_DB
# ⚠️ 安全警告：爬蟲資料庫（Crawler DB）的 SQLAlchemy 連線 DSN
CRAWLER_DB_URL=sqlite:///path/to/your/Crawler_DB

# ── Session 安全設定 ───────────────────────────────────────────────────────
# 儲存於 cookie 中的 session Token 識別名稱
SESSION_COOKIE_NAME=session_token
# Session 滑動有效期時間限制（秒，預設 8 小時）
SESSION_EXPIRE_SECONDS=28800
# Session 絕對生存上限時間（秒，預設 7 天）
SESSION_MAX_AGE_SECONDS=604800

# ── 邀請制與登入安全設定 ───────────────────────────────────────────────────
# 帳號邀請連結/邀請碼的有效時限（秒，預設 72 小時）
INVITATION_EXPIRE_SECONDS=259200
# 密碼暴力破解防禦：最大連續登入失敗嘗試次數限制
LOGIN_MAX_ATTEMPTS=5
# 登入失敗鎖定帳號的時間（秒，預設 15 分鐘）
LOGIN_LOCKOUT_SECONDS=900

# ── SMTP 郵件發送設定 ──────────────────────────────────────────────────────
# ⚠️ 安全警告：SMTP Console 模擬模式（true = 主控台輸出信件內容，false = SMTP 發信）
SMTP_CONSOLE_MODE=false
# SMTP 伺服器主機名稱（例如 smtp.gmail.com）
SMTP_HOST=smtp.gmail.com
# SMTP 連線埠號（通常為 TLS 的 587 或 SSL 的 465）
SMTP_PORT=587
# SMTP 連線時是否強制啟用 STARTTLS 傳輸安全
SMTP_USE_TLS=true
# ⚠️ 安全警告：嚴禁在此填入真實密碼並提交至 Git！
# 請將真實帳密設定於本機的 .env 中。
SMTP_USERNAME=your_smtp_username_here@gmail.com
SMTP_PASSWORD=your_gmail_app_password_here
# 發送邀請信時顯示的寄件者名稱
SMTP_FROM_NAME=外部連結檢查系統
# 發送邀請信時顯示的寄件者信箱（通常與 SMTP_USERNAME 相同）
SMTP_FROM_EMAIL=your_smtp_username_here@gmail.com

# ── 爬蟲核心系統設定 ───────────────────────────────────────────────────────
# 全域爬蟲限制與預設值設定檔路徑
GLOBAL_CONFIG_PATH=config/config_global.yaml
# ⚠️ 安全警告：正式生產環境請一律設為 false 以免被惡意利用發起 SSRF（伺服器請求偽造）攻擊！
# 僅在本地開發與測試時，允許將此設定設為 true 以允許爬蟲遍歷本機 localhost 與私有 IP（例如 127.0.0.1、192.168.*）。
CRAWLER_ALLOW_LOCAL_IPS=false
# 爬蟲最大網頁讀取容量上限 (單位：Bytes，預設為 10MB = 10485760)
CRAWLER_MAX_CONTENT_LENGTH=10485760
# 遇到 HTTP 錯誤時，允許降級以 GET 請求試探的大型社群或防爬蟲網域 (多個以逗號分隔)
CRAWLER_SOCIAL_DOMAINS="facebook.com,fb.com,youtube.com,instagram.com,twitter.com,linkedin.com"
