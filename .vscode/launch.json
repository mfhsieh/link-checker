{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "▶️ 啟動 Web 伺服器 (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/cli.py",
            "args": [
                "--serve",
                "--reload"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        },
        {
            "name": "🌐 啟動 Mock 測試伺服器 (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/test/test_server/server.py",
            "args": [
                "8080"
            ],
            "console": "integratedTerminal",
        },
        {
            "name": "🕸️ 測試單一網址 (Debug)",
            "type": "debugpy",
            "request": "launch",
            "program": "${workspaceFolder}/scripts/test_url.py",
            "args": [
                "${input:targetUrl}"
            ],
            "console": "integratedTerminal",
            "justMyCode": true
        }
    ],
    "inputs": [
        {
            "id": "targetUrl",
            "type": "promptString",
            "description": "請輸入要測試的網址",
            "default": "https://example.com"
        }
    ]
}