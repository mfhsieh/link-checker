# ==============================================================================
# 網站連結檢查系統 - 任務設定檔範例
# ==============================================================================
# 此檔案可用於透過命令列 (CLI) 直接啟動爬蟲任務。
# 指令範例：python cli.py -c job/config_job.yaml
# ==============================================================================

# [必填] 爬蟲開始巡覽的第一個網頁網址，請包含 http:// 或 https:// 前綴。
start_url: "https://www.example.com/"

# [必填] 目標網域 (Target Domains)
# 限制爬蟲僅深入探索這些網域的內部連結，不會跑到別人的網站去。
target_domains:
  - "www.example.com"
  - "blog.example.com"

# [選填] 信任網域 (Trusted Domains)
# 屬於這些網域的連結將被視為內部連結，不會作為「外部連結」結果輸出並探測。
trusted_domains:
  - "example.com"

# ==============================================================================
# 爬蟲行為覆寫區塊 (Crawler Settings)
# 若有填寫，將與系統全域設定檔 (config_global.yaml) 進行合併與覆寫。
# ==============================================================================
crawler:
  # 每次發送 HTTP 請求前的等待延遲時間 (單位：秒)
  delay: 3.0
  
  # 單頁抓取總等待時間 (單位：秒)
  timeout: 30
  
  # TCP 建立連線等待時間 (單位：秒)
  connect_timeout: 5.0
  
  # 外連存活檢查等待時間 (單位：秒)
  external_check_timeout: 10.0
  
  # 發生暫時性錯誤時的重試次數
  retries: 3
  
  # 最大爬取深度限制 (從起點開始點擊的層數，null 代表無限制)
  max_depth: 2
  
  # 總抓取實質網頁頁面數量上限 (null 代表無限制)
  max_pages: 100
  
  # 網域特定請求延遲設定 (支援最長匹配優先原則，用以精確調控特定目標網站的請求頻率)
  domain_delays:
    "slow.example.com": 10.0

  # 額外要略過解析的副檔名 (將與全域設定合併疊加生效【聯集】)
  ignore_extensions:
    - ".custom_ext"

  # 額外排除的路徑規則 Regex (匹配這些正則表達式的路徑將被略過。將與全域設定合併疊加生效【聯集】)
  ignore_regexes:
    - "^https://www\\.example\\.com/logout"

  # 信任的自簽憑證豁免網域白名單 (位於此清單之網域將豁免 SSL 鏈結校驗。將與全域設定合併疊加生效【聯集】)
  ssl_exempt_domains:
    - "internal-self-signed.local"

  # 額外的社群與反爬蟲網域清單 (遇到 >= 400 錯誤會自動降級為 GET 探測。將與全域合併疊加生效【聯集】)
  social_domains:
    - "custom-social-media.com"

  # 自訂 HTTP 請求標頭 User-Agent
  # 若不設定 (null) 或未填寫，系統將自動啟用高擬真動態瀏覽器特徵與標頭輪替，防範 WAF 阻擋
  user_agent: null

  # 自訂代理伺服器 URL (例如 "http://user:pass@proxy.example.com:8080")
  # 若需隱藏來源 IP 可在此設定，亦可透過環境變數 CRAWLER_PROXY_URL 設定 (環境變數優先層級最高)
  proxy_url: null

  # MIME 類型過濾開關，防止爬蟲下載非網頁媒體資源浪費頻寬
  mime_type_filter:
    enabled: true
    allowed_types:
      - "text/html"
      - "application/xhtml+xml"